# AI Provider Keys (at least one required)
# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get your Z.AI API key from https://z.ai (optional, for voice analysis)
Z_AI_API_KEY=your_z_ai_api_key_here

# Database — Neon PostgreSQL recommended for Vercel
DATABASE_URL_VOCAL=postgresql://user:password@ep-xxx.region.aws.neon.tech/vocalplan?sslmode=require

# Auth
NEXTAUTH_URL=https://your-app-name.vercel.app
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
